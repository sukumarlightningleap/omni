generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model StoreConfig {
  id                String    @id @default("global")
  flashSaleActive   Boolean   @default(false)
  flashSaleEndsAt   DateTime?
  flashSaleMessage  String    @default("LIMITED DROP ENDING SOON")
  heroVideoUrls     String[]  @default([])
  heroImageUrl      String?
  promoAnnouncement String?
}

model DiscoveryItem {
  id                String      @id @default(cuid())
  section           String      // "BUDGET", "OMG", "CATEGORY", "TRENDING"
  collectionId      String
  collection        Collection  @relation(fields: [collectionId], references: [id])
  customImageUrl    String?     @db.Text
  customDescription String?     @db.Text
  order             Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([section])
  @@unique([section, collectionId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          Role      @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  internalNotes String?
  totalSpent    Float     @default(0)
  accounts      Account[]
  orders        Order[]
  sessions      Session[]
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String?     @unique
  userId          String?
  stripeSessionId String?     @unique
  printifyOrderId String?     @unique
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  totalPaid       Float?      @default(0)
  profit          Float?      @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  internalNotes   String?
  shippingAddress String?
  trackingNumber  String?
  carrier         String?
  trackingUrl     String?
  user            User?        @relation(fields: [userId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  variantId String?
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LookbookImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  createdAt DateTime @default(now())
}

model Collection {
  id            String    @id @default(cuid())
  name          String
  handle        String    @unique // e.g., "spring-2026-drop"
  description   String?   @db.Text
  imageUrl      String?
  products      Product[] // 1-to-many relation
  discoveryItems DiscoveryItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Product {
  id            String      @id @default(cuid())
  printifyId    String      @unique
  name          String
  description   String?     @db.Text
  metaDescription String?    @db.Text
  price         Float       // Retail price
  cost          Float?      // Printify base cost
  imageUrl      String

  // 1-to-many Relation
  collectionId  String?
  collection    Collection? @relation(fields: [collectionId], references: [id])

  orderItems    OrderItem[]
  status        ProductStatus @default(DRAFT)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum Role {
  ADMIN
  CUSTOMER
  VIP
}

enum ProductStatus {
  LIVE
  DRAFT
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  MANUAL_INTERVENTION_REQUIRED
}
